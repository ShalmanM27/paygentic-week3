{
  "name": "credit",
  "version": "0.1.0",
  "private": true,
  "description": "CREDIT — agent-to-agent lending on Locus (Paygentic Week 3)",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "demo": "tsx packages/credit-agent/scripts/demo-runner.ts",
    "dev:web": "pnpm --filter @credit/frontend dev",
    "verify": "tsx packages/credit-agent/scripts/verify.ts",
    "reset-and-run": "tsx packages/credit-agent/scripts/reset-and-run.ts",
    "typecheck": "pnpm -r typecheck",
    "test:all": "pnpm test:credit-flow && pnpm test:webhook-flow && pnpm test:loops && pnpm test:borrow-flow && pnpm test:e2e-loop && pnpm test:frontend-routes && pnpm test:task-flow && pnpm test:add-agent",
    "test:credit-flow": "tsx packages/credit-agent/scripts/test-credit-flow.ts",
    "test:webhook-flow": "tsx packages/credit-agent/scripts/test-webhook-flow.ts",
    "test:loops": "tsx packages/credit-agent/scripts/test-loops.ts",
    "test:borrow-flow": "tsx packages/borrower/scripts/test-borrow-flow.ts",
    "test:e2e-loop": "tsx packages/credit-agent/scripts/test-e2e-loop.ts",
    "test:frontend-routes": "tsx packages/credit-agent/scripts/test-frontend-routes.ts",
    "test:task-flow": "tsx packages/credit-agent/scripts/test-task-flow.ts",
    "test:add-agent": "tsx packages/credit-agent/scripts/test-add-agent.ts",
    "smoke:gemini": "tsx packages/borrower/scripts/smoke-gemini.ts",
    "smoke:locus": "tsx packages/shared/scripts/smoke-locus.ts",
    "smoke:webhook": "tsx packages/shared/scripts/smoke-webhook.ts",
    "seed:wallets": "tsx packages/shared/scripts/seed-wallets.ts",
    "dev:credit": "pnpm --filter @credit/credit-agent dev",
    "dev:summarizer": "pnpm --filter @credit/agent-summarizer dev",
    "dev:reviewer": "pnpm --filter @credit/agent-code-reviewer dev",
    "dev:writer": "pnpm --filter @credit/agent-code-writer dev",
    "dev:customer": "pnpm --filter @credit/customer-agent dev",
    "dev:all": "concurrently -n credit,sum,rev,wri,cust,web -c blue,green,yellow,cyan,magenta,white \"pnpm dev:credit\" \"pnpm dev:summarizer\" \"pnpm dev:reviewer\" \"pnpm dev:writer\" \"pnpm dev:customer\" \"pnpm dev:web\"",
    "_archived": "smoke:pay archived 2026-04-30 — see smoke-pay.ts header and CLAUDE.md decision block"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
